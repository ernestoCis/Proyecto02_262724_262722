<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence                         https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
  <persistence-unit name="ConexionPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
    <class>entidades.Cliente</class>
    <class>entidades.Comanda</class>
    <class>entidades.ClienteFrecuente</class>
    <class>entidades.Empleado</class>
    <class>entidades.Mesero</class>
    <class>entidades.Mesa</class>
    <class>entidades.Producto</class>
    <class>entidades.Ingrediente</class>
    <class>entidades.Receta</class>
    <properties>
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/Restaurante"/>
      <property name="jakarta.persistence.jdbc.user" value="root"/>
      <property name="jakarta.persistence.jdbc.password" value="pau"/>
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
      <property name="hibernate.hbm2ddl.auto" value="update"/>
      <property name="hibernate.show_sql" value="true"/>
    </properties>
  </persistence-unit>
</persistence>
